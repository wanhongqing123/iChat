            android:pathData="M 31 54 m -7 0 a 7 7 0 1 0 14 0 a 7 7 0 1 0 -14 0 Z" />
        <path
            android:fillColor="#FFFFFFFF"
            android:pathData="M 54 54 m -7 0 a 7 7 0 1 0 14 0 a 7 7 0 1 0 -14 0 Z" />
